# Tehnikavija – SMTP credentials
# Copy this file to .env (gitignored) and fill in your values.

# Gmail SMTP (recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=miha.pog@gmail.com
# Generate at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the account)
SMTP_PASS=xxxx xxxx xxxx xxxx

# Sender display name shown in the customer's inbox
FROM_NAME=Tehnikavija
